DATABASE_URL="postgresql://travelagencyweb_user:CHANGE_ME@travelagencyweb-postgres:5432/travelagencyweb_db?schema=public"
JWT_SECRET="change-this-to-a-random-64-char-string"
NODE_ENV=production
PORT=3027
CORS_ORIGIN="https://travelagencyweb.com,https://www.travelagencyweb.com,https://app.travelagencyweb.com,https://portal.travelagencyweb.com"

# Customer / supplier portal URL (used inside magic-link emails)
PORTAL_URL=https://portal.travelagencyweb.com
UPLOAD_DIR="/app/uploads"
LOG_DIR="/app/logs"
PUBLIC_UPLOAD_URL="https://api.travelagencyweb.com/uploads"


# ── SMTP (optional — emails logged to console without these) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@travelagencyweb.com
SMTP_FROM_NAME=Travel Agency Web

# Frontend URL for email links and payment callbacks
FRONTEND_URL=https://travelagencyweb.com

# Backend API base URL (for payment gateway callbacks)
API_BASE_URL=https://api.travelagencyweb.com/api

# Admin notification email (receives demo/contact form alerts)
ADMIN_NOTIFICATION_EMAIL=

# Cron secret for subscription expiry job
CRON_SECRET=

# ── SSLCommerz ──
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true

# ── bKash ──
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true

# ── SMS ──
SMS_PROVIDER=console
# For Twilio:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# For BulkSMSBD:
SMS_API_KEY=
SMS_SENDER_ID=

# ── WhatsApp ──
WHATSAPP_PROVIDER=console
# For Twilio WhatsApp:
WHATSAPP_FROM_NUMBER=whatsapp:+14155238886
# For Meta WhatsApp Business:
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
